            <effect_group>
                <passive_effect name="EntityDamage" operation="perc_add" value=".05"/>
            </effect_group>
        </buff>

        <buff name="buffWafuuAttackUp10_120" duration="120" stack="replace"
              name_key="buffWafuuAttackUp10_120" description_key="buffWafuuAttackUp10_120_desc"
              icon="ui_game_symbol_sword" icon_color="255,68,68">
            <effect_group>
                <passive_effect name="EntityDamage" operation="perc_add" value=".10"/>
            </effect_group>
        </buff>


        <!-- ==================== HP 継続回復 (HoT) ==================== -->

        <buff name="buffWafuuHoT45" duration="45" stack="replace"
              name_key="buffWafuuHoT45" description_key="buffWafuuHoT45_desc"
              icon="ui_game_symbol_natural_healing" icon_color="68,255,68">
            <effect_group>
                <triggered_effect trigger="onSelfBuffUpdate" action="ModifyCVar" cvar=".health" operation="add" value="1"/>
            </effect_group>
        </buff>

        <buff name="buffWafuuHoT60" duration="60" stack="replace"
              name_key="buffWafuuHoT60" description_key="buffWafuuHoT60_desc"
              icon="ui_game_symbol_natural_healing" icon_color="68,255,68">
            <effect_group>
                <triggered_effect trigger="onSelfBuffUpdate" action="ModifyCVar" cvar=".health" operation="add" value="1"/>
            </effect_group>
        </buff>

        <buff name="buffWafuuHoT90" duration="90" stack="replace"
              name_key="buffWafuuHoT90" description_key="buffWafuuHoT90_desc"
              icon="ui_game_symbol_natural_healing" icon_color="68,255,68">
            <effect_group>
                <triggered_effect trigger="onSelfBuffUpdate" action="ModifyCVar" cvar=".health" operation="add" value="1"/>
            </effect_group>
        </buff>

        <buff name="buffWafuuHoT2_60" duration="60" stack="replace"
              name_key="buffWafuuHoT2_60" description_key="buffWafuuHoT2_60_desc"
