<configs>
    <append xpath="/buffs">

        <!-- ======================================================== -->
        <!-- ToshiDev Wafuu Overhaul — バフ定義                         -->
        <!-- items.xml の effect_group から参照される                     -->
        <!-- ======================================================== -->


        <!-- ==================== 寒冷耐性 ==================== -->

        <buff name="buffWafuuColdResist30" duration="30" stack="replace"
              name_key="buffWafuuColdResist30" description_key="buffWafuuColdResist30_desc"
              icon="ui_game_symbol_cold" icon_color="136,204,255">
            <effect_group>
                <passive_effect name="HypothermalResist" operation="base_add" value="15"/>
            </effect_group>
        </buff>

        <buff name="buffWafuuColdResist60" duration="60" stack="replace"
              name_key="buffWafuuColdResist60" description_key="buffWafuuColdResist60_desc"
              icon="ui_game_symbol_cold" icon_color="136,204,255">
            <effect_group>
                <passive_effect name="HypothermalResist" operation="base_add" value="15"/>
            </effect_group>
        </buff>


        <!-- ==================== 暑熱耐性 ==================== -->

        <buff name="buffWafuuHeatResist60" duration="60" stack="replace"
              name_key="buffWafuuHeatResist60" description_key="buffWafuuHeatResist60_desc"
              icon="ui_game_symbol_hot" icon_color="255,136,68">
            <effect_group>
                <passive_effect name="HyperthermalResist" operation="base_add" value="15"/>
            </effect_group>
        </buff>

        <buff name="buffWafuuHeatResist120" duration="120" stack="replace"
              name_key="buffWafuuHeatResist120" description_key="buffWafuuHeatResist120_desc"
              icon="ui_game_symbol_hot" icon_color="255,136,68">
            <effect_group>
                <passive_effect name="HyperthermalResist" operation="base_add" value="15"/>
            </effect_group>
        </buff>


        <!-- ==================== 攻撃力アップ ==================== -->

        <buff name="buffWafuuAttackUp3_30" duration="30" stack="replace"
              name_key="buffWafuuAttackUp3_30" description_key="buffWafuuAttackUp3_30_desc"
              icon="ui_game_symbol_sword" icon_color="255,160,160">
            <effect_group>
                <passive_effect name="EntityDamage" operation="perc_add" value=".03"/>
            </effect_group>
        </buff>

        <buff name="buffWafuuAttackUp5_30" duration="30" stack="replace"
              name_key="buffWafuuAttackUp5_30" description_key="buffWafuuAttackUp5_30_desc"
              icon="ui_game_symbol_sword" icon_color="255,100,100">
            <effect_group>
                <passive_effect name="EntityDamage" operation="perc_add" value=".05"/>
            </effect_group>
        </buff>

        <buff name="buffWafuuAttackUp5_60" duration="60" stack="replace"
              name_key="buffWafuuAttackUp5_60" description_key="buffWafuuAttackUp5_60_desc"
