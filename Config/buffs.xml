        <buff name="buffWafuuSpeedUp10_90" duration="90" stack="replace"
              name_key="buffWafuuSpeedUp10_90" description_key="buffWafuuSpeedUp10_90_desc"
              icon="ui_game_symbol_run" icon_color="0,230,230">
            <effect_group>
                <passive_effect name="RunSpeed" operation="perc_add" value=".10"/>
            </effect_group>
        </buff>


        <!-- ==================== クラフト速度アップ ==================== -->

        <buff name="buffWafuuCraftSpeed60" duration="60" stack="replace"
              name_key="buffWafuuCraftSpeed60" description_key="buffWafuuCraftSpeed60_desc"
              icon="ui_game_symbol_hammer" icon_color="255,255,68">
            <effect_group>
                <passive_effect name="CraftingTime" operation="perc_add" value="-.10"/>
