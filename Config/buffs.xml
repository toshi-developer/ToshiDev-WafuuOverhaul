              icon="ui_game_symbol_run" icon_color="68,255,255">
            <effect_group>
                <passive_effect name="RunSpeed" operation="perc_add" value=".05"/>
            </effect_group>
        </buff>

        <buff name="buffWafuuSpeedUp5_45" duration="45" stack="replace"
              name_key="buffWafuuSpeedUp5_45" description_key="buffWafuuSpeedUp5_45_desc"
              icon="ui_game_symbol_run" icon_color="68,255,255">
            <effect_group>
                <passive_effect name="RunSpeed" operation="perc_add" value=".05"/>
