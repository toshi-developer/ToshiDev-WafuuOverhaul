        </buff>

        <buff name="buffWafuuDiseaseResist180" duration="180" stack="replace"
              name_key="buffWafuuDiseaseResist180" description_key="buffWafuuDiseaseResist180_desc"
              icon="ui_game_symbol_medical" icon_color="255,255,255">
            <effect_group>
                <passive_effect name="DiseaseResist" operation="base_add" value="30"/>
            </effect_group>
        </buff>


        <!-- ==================== 酩酊 ==================== -->

        <!-- 日本酒: 攻撃力+10%, 防御-5%, 120秒 -->
        <buff name="buffWafuuDrunkLight" duration="120" stack="replace"
              name_key="buffWafuuDrunkLight" description_key="buffWafuuDrunkLight_desc"
              icon="ui_game_symbol_skull" icon_color="204,68,255">
            <effect_group>
                <passive_effect name="EntityDamage" operation="perc_add" value=".10"/>
                <passive_effect name="PhysicalDamageResist" operation="perc_add" value="-.05"/>
            </effect_group>
        </buff>

        <!-- 焼酎: 攻撃力+15%, 防御-10%, 120秒 -->
        <buff name="buffWafuuDrunkHeavy" duration="120" stack="replace"
              name_key="buffWafuuDrunkHeavy" description_key="buffWafuuDrunkHeavy_desc"
              icon="ui_game_symbol_skull" icon_color="180,40,255">
            <effect_group>
                <passive_effect name="EntityDamage" operation="perc_add" value=".15"/>
                <passive_effect name="PhysicalDamageResist" operation="perc_add" value="-.10"/>
            </effect_group>
        </buff>

    </append>
</configs>
