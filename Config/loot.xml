<configs>

    <!-- ======================================================== -->
    <!-- ToshiDev Wafuu Overhaul — ルートテーブル                    -->
    <!-- 和風素材・調味料・食料をバニラのルートコンテナに追加          -->
    <!-- v2.5 対応: アイテムを直接注入（lootgroup 前方参照問題を回避）-->
    <!-- ======================================================== -->


    <!-- ==================== バニラルートコンテナへの注入 ==================== -->

    <!-- 一般食料（Common）: 調味料・作物・保存食 -->
    <append xpath="/lootcontainers/lootgroup[@name='groupFoodCommon']">
        <item name="foodSoySauce"   count="1,2" prob="0.04"/>
        <item name="foodSalt"       count="1,3" prob="0.04"/>
        <item name="foodMiso"       count="1,2" prob="0.03"/>
        <item name="foodRice"       count="1,3" prob="0.04"/>
        <item name="cropSoybean"    count="1,2" prob="0.03"/>
        <item name="cropDaikon"     count="1,2" prob="0.03"/>
        <item name="foodUmeboshi"   count="1,2" prob="0.03"/>
        <item name="foodTakuan"     count="1,2" prob="0.03"/>
        <item name="foodSenbei"     count="1,3" prob="0.03"/>
    </append>

    <!-- 上位食料（Uncommon）: 作物・調理済み -->
    <append xpath="/lootcontainers/lootgroup[@name='groupFoodUncommon']">
        <item name="cropHakusai"    count="1,2" prob="0.03"/>
        <item name="cropShiitake"   count="1,2" prob="0.03"/>
        <item name="foodTofu"       count="1,2" prob="0.03"/>
        <item name="foodOnigiriUme" count="1,2" prob="0.02"/>
        <item name="foodYakitori"   count="1,2" prob="0.02"/>
        <item name="foodHimono"     count="1,2" prob="0.02"/>
    </append>

    <!-- レア食料: 調理済み和食 -->
    <append xpath="/lootcontainers/lootgroup[@name='groupFoodRare']">
        <item name="foodGrilledSalmon" count="1" prob="0.02"/>
        <item name="foodOnigiriSake"   count="1" prob="0.02"/>
        <item name="foodDaifuku"       count="1" prob="0.02"/>
        <item name="foodMochi"         count="1" prob="0.02"/>
    </append>

    <!-- Shamway 棚: 全カテゴリ -->
    <append xpath="/lootcontainers/lootgroup[@name='groupShamwayShelves01']">
        <item name="foodSoySauce"   count="1,2" prob="0.05"/>
        <item name="foodMiso"       count="1,2" prob="0.04"/>
        <item name="foodDashi"      count="1,2" prob="0.03"/>
        <item name="foodFlour"      count="1,2" prob="0.04"/>
        <item name="foodRice"       count="1,3" prob="0.05"/>
        <item name="cropSoybean"    count="1,2" prob="0.03"/>
        <item name="foodUmeboshi"   count="1,2" prob="0.03"/>
        <item name="foodTakuan"     count="1,2" prob="0.03"/>
        <item name="foodSenbei"     count="2,5" prob="0.04"/>
        <item name="drinkGreenTea"  count="1,2" prob="0.04"/>
        <item name="drinkMugicha"   count="1,2" prob="0.03"/>
    </append>

    <!-- ゴミ箱: 低確率で保存食 -->
    <append xpath="/lootcontainers/lootgroup[@name='groupFoodTrashCommon']">
        <item name="foodUmeboshi"   count="1" prob="0.02"/>
        <item name="foodSenbei"     count="1,2" prob="0.02"/>
        <item name="foodTsukudani"  count="1,2" prob="0.01"/>
    </append>

    <!-- 飲料棚: 和風飲料 -->
    <append xpath="/lootcontainers/lootgroup[@name='groupDrinksCommon']">
        <item name="drinkGreenTea"  count="1,2" prob="0.05"/>
        <item name="drinkMugicha"   count="1,2" prob="0.04"/>
        <item name="drinkAmazake"   count="1"   prob="0.02"/>
    </append>

    <!-- レア飲料: 酒 -->
    <append xpath="/lootcontainers/lootgroup[@name='groupDrinksRare']">
        <item name="drinkNihonshu"  count="1" prob="0.02"/>
        <item name="drinkShochu"    count="1" prob="0.01"/>
    </append>


    <!-- ==================== 武器ルート ==================== -->

    <!-- 近接武器: T1 メレー -->
    <append xpath="/lootcontainers/lootgroup[@name='groupWeaponsT0_Melee']">
        <item name="meleeWpnWafuuBokuto"   prob="0.03"/>
        <item name="meleeWpnWafuuTakeyari"  prob="0.03"/>
    </append>

    <!-- 近接武器: T2 メレー -->
    <append xpath="/lootcontainers/lootgroup[@name='groupWeaponsT1_Melee']">
        <item name="meleeWpnWafuuKatana"    prob="0.02"/>
        <item name="meleeWpnWafuuNaginata"  prob="0.02"/>
    </append>

    <!-- 近接武器: T3 メレー -->
    <append xpath="/lootcontainers/lootgroup[@name='groupWeaponsT2_Melee']">
        <item name="meleeWpnWafuuTachi"          prob="0.015"/>
        <item name="meleeWpnWafuuJumonjiYari"    prob="0.015"/>
        <item name="meleeWpnWafuuKanabo"         prob="0.015"/>
        <item name="meleeWpnWafuuKusarigama"     prob="0.015"/>
    </append>

    <!-- 弓: T0-T1 -->
    <append xpath="/lootcontainers/lootgroup[@name='groupWeaponsT0_Archery']">
        <item name="gunBowWafuuWakyuu"  prob="0.03"/>
    </append>

    <append xpath="/lootcontainers/lootgroup[@name='groupWeaponsT1_Archery']">
        <item name="gunBowWafuuHankyuu"  prob="0.02"/>
    </append>

    <!-- 火縄銃: T2 ライフル -->
    <append xpath="/lootcontainers/lootgroup[@name='groupWeaponsT2_DeadEye']">
        <item name="gunRifleWafuuTanegashima"  prob="0.015"/>
    </append>

    <!-- 矢: Arrow グループ -->
    <append xpath="/lootcontainers/lootgroup[@name='groupArrowSmall']">
        <item name="ammoArrowWafuuTake" count="5,15" prob="0.04"/>
    </append>
    <append xpath="/lootcontainers/lootgroup[@name='groupArrowMedium']">
        <item name="ammoArrowWafuuTake" count="10,25" prob="0.04"/>
        <item name="ammoArrowWafuuHi"   count="3,8"   prob="0.02"/>
        <item name="ammoArrowWafuuDoku" count="3,8"   prob="0.02"/>
    </append>
    <append xpath="/lootcontainers/lootgroup[@name='groupArrowLarge']">
        <item name="ammoArrowWafuuTake"  count="15,40" prob="0.04"/>
        <item name="ammoArrowWafuuHi"    count="5,15"  prob="0.03"/>
        <item name="ammoArrowWafuuDoku"  count="5,15"  prob="0.03"/>
        <item name="ammoArrowWafuuHakou" count="3,10"  prob="0.02"/>
    </append>

    <!-- 投擲武器: T1 投擲（手裏剣・くない） -->
    <append xpath="/lootcontainers/lootgroup[@name='groupWeaponsT0_Melee']">
        <item name="thrownWafuuShuriken" count="3,8"  prob="0.03"/>
    </append>

    <append xpath="/lootcontainers/lootgroup[@name='groupWeaponsT1_Melee']">
        <item name="thrownWafuuShuriken" count="5,15" prob="0.02"/>
        <item name="thrownWafuuKunai"    count="2,6"  prob="0.02"/>
    </append>

    <append xpath="/lootcontainers/lootgroup[@name='groupWeaponsT2_Melee']">
        <item name="thrownWafuuKunai"    count="3,10" prob="0.015"/>
        <item name="thrownWafuuSmokeBomb" count="1,3" prob="0.010"/>
    </append>


    <!-- ==================== 薬草・和漢薬ルート ==================== -->

    <!-- 野草・植物系コンテナに薬草を追加 -->
    <append xpath="/lootcontainers/lootgroup[@name='groupFoodCommon']">
        <item name="resourceWafuuHerb" count="1,3" prob="0.04"/>
    </append>

    <append xpath="/lootcontainers/lootgroup[@name='groupFoodUncommon']">
        <item name="resourceWafuuHerb" count="2,5" prob="0.03"/>
    </append>

    <!-- 医療品コンテナに和漢薬を追加 -->
    <append xpath="/lootcontainers/lootgroup[@name='groupMedicalCommon']">
        <item name="medWafuuHerbTea"     count="1,2" prob="0.03"/>
        <item name="medWafuuKiyomeSalt"  count="1,2" prob="0.03"/>
        <item name="resourceWafuuHerb"   count="2,4" prob="0.04"/>
    </append>

    <append xpath="/lootcontainers/lootgroup[@name='groupMedicalUncommon']">
        <item name="medWafuuWoundSalve"  count="1" prob="0.03"/>
        <item name="medWafuuAntidote"    count="1" prob="0.02"/>
        <item name="medWafuuHerbTea"     count="1,2" prob="0.03"/>
    </append>

    <append xpath="/lootcontainers/lootgroup[@name='groupMedicalRare']">
        <item name="medWafuuOmamori"     count="1" prob="0.02"/>
        <item name="medWafuuAntidote"    count="1" prob="0.02"/>
    </append>

    <!-- Shamway 棚にも薬草を少量追加 -->
    <append xpath="/lootcontainers/lootgroup[@name='groupShamwayShelves01']">
        <item name="resourceWafuuHerb"   count="1,2" prob="0.03"/>
        <item name="medWafuuHerbTea"     count="1"   prob="0.02"/>
    </append>


    <!-- ==================== 防具ルート ==================== -->

    <append xpath="/lootcontainers/lootgroup[@name='groupAllArmor']">
        <item name="armorWafuuAshigaruHelmet"  prob="0.01"/>
        <item name="armorWafuuAshigaruChest"   prob="0.01"/>
        <item name="armorWafuuAshigaruGloves"  prob="0.01"/>
        <item name="armorWafuuAshigaruLegs"    prob="0.01"/>
        <item name="armorWafuuSamuraiHelmet"   prob="0.008"/>
        <item name="armorWafuuSamuraiChest"    prob="0.008"/>
        <item name="armorWafuuSamuraiGloves"   prob="0.008"/>
        <item name="armorWafuuSamuraiLegs"     prob="0.008"/>
        <item name="armorWafuuShinobiHelmet"   prob="0.008"/>
        <item name="armorWafuuShinobiChest"    prob="0.008"/>
        <item name="armorWafuuShinobiGloves"   prob="0.008"/>
        <item name="armorWafuuShinobiLegs"     prob="0.008"/>
        <item name="armorWafuuTaishoHelmet"    prob="0.005"/>
        <item name="armorWafuuTaishoChest"     prob="0.005"/>
        <item name="armorWafuuTaishoGloves"    prob="0.005"/>
        <item name="armorWafuuTaishoLegs"      prob="0.005"/>
    </append>

</configs>
